{
  "name": "@anitshrsth/assembly-kit",
  "version": "1.0.1",
  "description": "Alternative SDK for the Assembly platform",
  "homepage": "https://github.com/priosshrsth/assembly-kit#readme",
  "bugs": {
    "url": "https://github.com/priosshrsth/assembly-kit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priosshrsth/assembly-kit.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./assembly-kit": {
      "import": {
        "types": "./dist/assembly-kit/index.d.ts",
        "default": "./dist/assembly-kit/index.js"
      }
    },
    "./bridge-ui": {
      "import": {
        "types": "./dist/bridge-ui/index.d.ts",
        "default": "./dist/bridge-ui/index.js"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger/index.d.ts",
        "default": "./dist/logger/index.js"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas/index.d.ts",
        "default": "./dist/schemas/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "format": "ultracite fix",
    "lint": "ultracite check",
    "prepare": "lefthook install || true",
    "release": "bumpp --commit --push --tag",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "type-check": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json"
  },
  "dependencies": {
    "p-retry": "^7.1.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@assembly-js/app-bridge": "^1.1.1",
    "@assembly-js/node-sdk": "^3.19.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.11.1",
    "@types/react": "^19.2.14",
    "bumpp": "^11.0.1",
    "bunup": "^0.16.31",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.2"
  },
  "peerDependencies": {
    "@assembly-js/app-bridge": "^1.1.1",
    "@assembly-js/node-sdk": "^3.19.1",
    "react": ">=18",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "@assembly-js/app-bridge": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
